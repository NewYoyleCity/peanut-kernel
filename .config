#
# Automatically generated file; DO NOT EDIT.
# Peanut Kernel Configuration
#

#
# General Setup
#
CONFIG_KERNEL_NAME="Peanut Kernel"
CONFIG_KERNEL_VERSION="0.0.1-alpha"
CONFIG_INIT_PATH="/sbin/init"

#
# Advanced Features (for experts only)
#
# CONFIG_ADV_WRITE_TEST is not set

#
# Memory Management
#
CONFIG_VM=y
CONFIG_SLAB_ALLOCATOR=y
CONFIG_KASLR=y

#
# Scheduler
#
CONFIG_SCHED_RR=y
# CONFIG_SCHED_CFS is not set
CONFIG_SCHED_MAX_PROCS=2000

#
# Boot Support
#
# CONFIG_BOOT_UEFI is not set
# CONFIG_INITRAMFS_EMBED is not set

#
# Device Drivers
#

#
# CD-ROM drivers
#
# CONFIG_STORAGE_CDROM is not set

#
# Floppy drivers
#
# CONFIG_STORAGE_FLOPPY is not set

#
# Network drivers
#
CONFIG_NET_TCP_IP=y
CONFIG_NET_E1000=y
CONFIG_NET_RTL8139=y
CONFIG_NET_RTL8169=y
CONFIG_NET_VIRTIO=y

#
# Audio drivers
#
CONFIG_AUDIO_AC97=y
CONFIG_AUDIO_HDA=y

#
# ATA/Storage drivers
#
CONFIG_STORAGE_IDE=y
CONFIG_STORAGE_AHCI=y
CONFIG_STORAGE_TESTS=y

#
# USB drivers
#
CONFIG_USB_XHCI=y

#
# Input drivers
#
CONFIG_INPUT_PS2=y

#
# Video drivers
#
CONFIG_VIDEO_HDMI=y

#
# Graphics drivers
#
CONFIG_VGA_TEXT=y
CONFIG_VGA_COLOR=0x0F

#
# Filesystems
#

#
# FAT12
#
CONFIG_FS_FAT12_READ=y
CONFIG_FS_FAT12_WRITE=y

#
# FAT16
#
CONFIG_FS_FAT16_READ=y
CONFIG_FS_FAT16_WRITE=y

#
# FAT32
#
CONFIG_FS_FAT32_READ=y
CONFIG_FS_FAT32_WRITE=y

#
# exFAT
#
CONFIG_FS_EXFAT_READ=y
CONFIG_FS_EXFAT_WRITE=y

#
# ext2
#
# CONFIG_FS_EXT2_READ is not set

#
# ext3
#
# CONFIG_FS_EXT3_READ is not set

#
# ext4
#
CONFIG_FS_EXT4_READ=y
CONFIG_FS_EXT4_WRITE=y

#
# Networking
#
CONFIG_NETWORK_SYSCALLS=y
CONFIG_DNS_RESOLVER=y

#
# Userspace Support
#
CONFIG_ELF_LOADER=y
